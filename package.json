    "min-height": 320
  },
  "scene-script": "scene.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "watch": "tsc -w -p tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^20.17.57",
    "typescript": "^5.8.3"
  }
}
