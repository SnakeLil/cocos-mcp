{
  "name": "cocos-mcp",
  "version": "0.1.0",
  "description": "MCP server extension for Cocos Creator 2.x",
  "author": "OpenAI Codex",
  "license": "MIT",
  "main": "main.js",
  "main-menu": {
    "Panel/Cocos MCP 2.x": {
      "message": "cocos-mcp:open-panel"
    }
  },
  "panel": {
    "main": "panel/index.js",
    "type": "dockable",
